# Provider binaries and state. State can contain secrets; never commit it.
.terraform/
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Saved plan files can contain sensitive values; treat them like state.
tfplan
*.tfplan

# Crash logs.
crash.log
crash.*.log

# Local secret overrides and token files, if ever used.
*.tfvars.local
.env
.envrc
*_override.tf
*_override.tf.json
override.tf
override.tf.json

# The lock file (.terraform.lock.hcl) is intentionally NOT ignored: commit it.
